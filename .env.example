# Core Configurations
DRY_RUN=true                      # Set to false to send real emails
SENDER_NAME="Your Name"

# Candidate Profile Configurations
CANDIDATE_BACKGROUND="Python developer interested in automation and AI agents"
PORTFOLIO_URL="https://github.com/yourname"

# Groq LLM Configurations
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile  # or llama3-8b-8192

# SMTP Configurations
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
